# Development Environment Variables Template
# Copy this file to .env and fill in your actual values
# For Docker deployment, use .env.docker

# Authentication
# Generate a secure random key: openssl rand -base64 32
AUTH_SECRET=your-secure-random-key-here

# Database - SQLite for local development
# Generate a secure random key: openssl rand -base64 32
DB_ENCRYPTION_KEY=your-database-encryption-key-here
DATABASE_PATH=./data/schedx.db

# Twitter Cookie Encryption
# Generate a secure random key: openssl rand -base64 32
API_KEY_ENCRYPTION_KEY=your-api-key-encryption-key-here

# Host setting - localhost for local development
HOST=0.0.0.0
ORIGIN=http://localhost:5173
PORT=5173

# Node environment - development for local dev
NODE_ENV=development

# Max upload size for individual files (50MB in bytes)
MAX_UPLOAD_SIZE=52428800

# Push Notifications (VAPID Keys)
# Generate keys with: npx web-push generate-vapid-keys
# Leave empty to disable push notifications
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_SUBJECT=mailto:admin@schedx.app
