    "@node-rs/argon2": "^1.8.3",
    "better-sqlite3": "^12.5.0",
    "socks": "^2.8.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.15.18",
    "typescript": "^5.0.0"
  }
}
