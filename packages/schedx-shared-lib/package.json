{
  "name": "@schedx/shared-lib",
  "version": "1.0.0",
  "description": "Shared library for SchedX app and scheduler",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./types/types": "./dist/types/types.js",
    "./backend": "./dist/backend/index.js",
    ".": "./dist/index.js"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', {recursive: true, force: true})\"",
